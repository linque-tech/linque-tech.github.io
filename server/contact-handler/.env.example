LISTEN_ADDR=127.0.0.1:8081

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@linque.eu
SMTP_PASS=your_smtp_password

# The address that appears in From: (defaults to SMTP_USER)
MAIL_FROM=noreply@linque.eu

# Where the form submissions are delivered
MAIL_TO=contact@linque.eu

# Lock down CORS to your actual domain once live
ALLOWED_ORIGIN=https://linque-tech.github.io
